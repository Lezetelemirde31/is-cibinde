# --- Database (same Postgres instance the frontend used to point Drizzle at) ---
DATABASE_URL="postgresql+psycopg://user:password@localhost:5432/is_cibinde"

# --- Site / CORS ---
SITE_URL="http://localhost:3000"
FRONTEND_ORIGIN="http://localhost:3000"

# --- Clerk (https://dashboard.clerk.com) ---
# Secret key is used to call the Clerk Backend API (fetch user email, set publicMetadata).
CLERK_SECRET_KEY="sk_test_xxx"
# Issuer is the Frontend API URL for your Clerk instance, e.g. https://your-app.clerk.accounts.dev
# Find it by decoding a session JWT's `iss` claim, or in Clerk Dashboard > API Keys > Advanced.
CLERK_ISSUER="https://your-app.clerk.accounts.dev"
CLERK_WEBHOOK_SECRET="whsec_xxx"

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID="xxx"
R2_ACCESS_KEY_ID="xxx"
R2_SECRET_ACCESS_KEY="xxx"
R2_BUCKET="is-cibinde"
R2_PUBLIC_URL="https://cdn.iscibinde.az"
